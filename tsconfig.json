{
  "extends": "./tsconfigs/strict.jsonc",
  "include": [
    ".astro/types.d.ts",
    "**/*"
  ],
  "exclude": [
    "dist"
  ],
  "compilerOptions": {
    "strictNullChecks": true,
    "jsx": "react-jsx",
    "target": "es2022",
    "moduleResolution": "nodenext",
    "module": "NodeNext",
    "types": [
      "@playwright/test"
    ]
  }
}